# Sky Deck — public runtime configuration (NEXT_PUBLIC_*, inlined at build time).
# All values are optional; each falls back to the current public host/value.
# No secrets belong here — these ship to the browser.

# ---- Map tiles ----
# Swap in a licensed or self-hosted tile source for production use.
# NEXT_PUBLIC_TILE_URL="https://your-tiles.example/{z}/{y}/{x}.png"
# NEXT_PUBLIC_TILE_ATTRIBUTION="© Your tile provider"
# NEXT_PUBLIC_TILE_MAXZOOM="19"

# Keep the WebGL drawing buffer (needed for canvas screenshots). Default: true.
# NEXT_PUBLIC_PRESERVE_DRAWING_BUFFER="true"

# ---- API base URLs (point these at a proxy you control for production) ----
# NEXT_PUBLIC_NOMINATIM_BASE="https://nominatim.openstreetmap.org"
# NEXT_PUBLIC_OPEN_METEO_BASE="https://api.open-meteo.com"
# NEXT_PUBLIC_OPEN_METEO_ARCHIVE_BASE="https://archive-api.open-meteo.com"
# NEXT_PUBLIC_COMMONS_BASE="https://commons.wikimedia.org"
# Comma-separated Overpass mirrors (the client races them).
# NEXT_PUBLIC_OVERPASS_ENDPOINTS="https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter"

# ---- Telemetry ----
# Presence of a DSN is the seam to wire a real error/analytics sink
# (see lib/telemetry.ts). Left unset, telemetry logs in dev and is a no-op in prod.
# NEXT_PUBLIC_TELEMETRY_DSN=""
